# Metabase
METABASE_PORT=3000
METABASE_ADMIN_EMAIL=admin@telecom-dw.local
METABASE_ADMIN_PASSWORD=Telecom@2025!
# Read-only DW role for Metabase (create with: scripts/metabase_setup.py)
DW_READER_USER=dw_reader
DW_READER_PASSWORD=reader_pw
